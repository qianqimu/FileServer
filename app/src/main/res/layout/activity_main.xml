<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 文件服务器"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 已停止"
                android:textSize="14sp"
                android:textColor="#9E9E9E"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 运行状态卡片（运行时显示） -->
        <LinearLayout
            android:id="@+id/card_running"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 在其他设备浏览器输入以下地址："
                android:textSize="13sp"
                android:textColor="#666666" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:background="#F5F7FF"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tv_url"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="http://192.168.1.1:8080"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#667EEA"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="20sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💡 点击地址可复制"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- 停止状态提示 -->
        <LinearLayout
            android:id="@+id/card_stopped"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴"
                android:textSize="40sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务未启动"
                android:textSize="16sp"
                android:textColor="#999999"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="配置好文件夹和端口后点击启动"
                android:textSize="12sp"
                android:textColor="#BBBBBB"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 配置卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ 配置"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="16dp" />

            <!-- 文件夹路径 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="共享文件夹"
                android:textSize="12sp"
                android:textColor="#888888" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_path"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="/sdcard"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:fontFamily="monospace"
                    android:background="#F5F5F5"
                    android:padding="10dp"
                    android:maxLines="2"
                    android:ellipsize="start" />

                <Button
                    android:id="@+id/btn_choose_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#667EEA"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp" />
            </LinearLayout>

            <!-- 端口号 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="端口号"
                android:textSize="12sp"
                android:textColor="#888888" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="8080"
                android:textSize="15sp"
                android:layout_marginTop="6dp"
                android:background="#F5F5F5"
                android:padding="10dp"
                android:hint="1024-65535" />
        </LinearLayout>

        <!-- 启动/停止按钮 -->
        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶ 启动服务"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#667EEA"
            android:layout_marginBottom="16dp" />

        <!-- 使用提示 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖 使用说明"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. 确保手机和电脑连接同一 WiFi 网络\n2. 选择要共享的文件夹\n3. 点击「启动服务」\n4. 在其他设备浏览器输入显示的地址\n5. 即可浏览和下载文件"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingMultiplier="1.6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️ 注意：首次使用需授予存储权限"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:layout_marginTop="10dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
